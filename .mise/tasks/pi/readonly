#!/usr/bin/env bash
#MISE description="Run pi in read-only sandbox mode"
#MISE raw=true
#MISE dir="{{cwd}}"
set -euo pipefail

launch_cwd="$(pwd -P)"
args=()
extra_folders=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--directory)
      if [[ $# -lt 2 ]]; then
        echo "pi: missing directory path for $1" >&2
        exit 1
      fi
      extra_folders+=("$2")
      shift 2
      ;;
    --directory=*)
      extra_folders+=("${1#--directory=}")
      shift
      ;;
    -v|--volume|--volume=*)
      echo "pi: -v/--volume was removed for mise wrappers; use -d/--directory instead" >&2
      exit 1
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ ${#extra_folders[@]} -gt 0 ]]; then
  export PI_SANDBOX_EXTRA_FOLDERS="$(node -e 'process.stdout.write(JSON.stringify(process.argv.slice(1)))' "${extra_folders[@]}")"
  export PI_SANDBOX_EXTRA_FOLDERS_CWD="$launch_cwd"
fi

PI_SANDBOX_LAUNCH_MODE=readonly "${MISE_PROJECT_ROOT}/scripts/pi-sandbox.sh" "${args[@]}"
