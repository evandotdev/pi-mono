#!/usr/bin/env bash
#MISE description="Unstow global mise pi tasks from ~/.config/mise"
set -euo pipefail

REPO_ROOT="${MISE_PROJECT_ROOT}"
STOW_ROOT="${REPO_ROOT}/stow"
PACKAGE_NAME="mise"
TARGET_ROOT="${HOME}"
MISE_CONFIG_DIR="${HOME}/.config/mise"
MANIFEST_PATH="${MISE_CONFIG_DIR}/.pi-mono-stow-manifest-mise"
BACKUP_ROOT="${MISE_CONFIG_DIR}/.pi-mono-stow-backups/mise"

if ! command -v stow >/dev/null 2>&1; then
  echo "pi:stow:mise:uninstall: 'stow' is not installed." >&2
  echo "Install GNU stow and rerun this command." >&2
  exit 1
fi

if [[ -d "${STOW_ROOT}/${PACKAGE_NAME}" ]]; then
  stow --dir "${STOW_ROOT}" --target "${TARGET_ROOT}" -D --no-folding "${PACKAGE_NAME}"
fi

hash_path() {
  local target_path="$1"

  DEST_PATH="${target_path}" node - <<'NODE'
const fs = require("node:fs");
const crypto = require("node:crypto");

const targetPath = process.env.DEST_PATH;
const stats = fs.lstatSync(targetPath);
if (stats.isDirectory()) {
  process.exit(1);
}

const data = fs.readFileSync(targetPath);
process.stdout.write(crypto.createHash("sha256").update(data).digest("hex"));
NODE
}

restored_count=0
removed_managed_sandbox_config=0
skipped_modified_sandbox_config=0
if [[ -f "${MANIFEST_PATH}" ]]; then
  timestamp=""
  sandbox_config_managed="0"
  sandbox_config_rel=""
  sandbox_config_sha256=""

  while IFS= read -r line; do
    case "${line}" in
      timestamp=*)
        timestamp="${line#timestamp=}"
        ;;
      meta:sandbox_config_managed=*)
        sandbox_config_managed="${line#meta:sandbox_config_managed=}"
        ;;
      meta:sandbox_config_rel=*)
        sandbox_config_rel="${line#meta:sandbox_config_rel=}"
        ;;
      meta:sandbox_config_sha256=*)
        sandbox_config_sha256="${line#meta:sandbox_config_sha256=}"
        ;;
    esac
  done < "${MANIFEST_PATH}"

  if [[ -n "${timestamp}" && -d "${BACKUP_ROOT}/${timestamp}" ]]; then
    while IFS= read -r rel; do
      [[ -z "${rel}" ]] && continue

      case "${rel}" in
        timestamp=*|meta:*)
          continue
          ;;
      esac

      backup_path="${BACKUP_ROOT}/${timestamp}/${rel}"
      dest="${TARGET_ROOT}/${rel}"

      if [[ ! -e "${backup_path}" && ! -L "${backup_path}" ]]; then
        continue
      fi
      if [[ -e "${dest}" || -L "${dest}" ]]; then
        continue
      fi

      mkdir -p "$(dirname "${dest}")"
      mv "${backup_path}" "${dest}"
      restored_count=$((restored_count + 1))
    done < "${MANIFEST_PATH}"
  fi

  if [[ "${sandbox_config_managed}" == "1" && -n "${sandbox_config_rel}" && -n "${sandbox_config_sha256}" ]]; then
    backup_path="${BACKUP_ROOT}/${timestamp}/${sandbox_config_rel}"
    dest="${TARGET_ROOT}/${sandbox_config_rel}"

    if [[ -e "${dest}" || -L "${dest}" ]]; then
      current_sha=""
      if current_sha="$(hash_path "${dest}" 2>/dev/null)" && [[ "${current_sha}" == "${sandbox_config_sha256}" ]]; then
        if [[ -e "${backup_path}" || -L "${backup_path}" ]]; then
          rm -rf "${dest}"
          mkdir -p "$(dirname "${dest}")"
          mv "${backup_path}" "${dest}"
          restored_count=$((restored_count + 1))
        else
          rm -rf "${dest}"
          removed_managed_sandbox_config=$((removed_managed_sandbox_config + 1))
        fi
      else
        skipped_modified_sandbox_config=$((skipped_modified_sandbox_config + 1))
      fi
    elif [[ -e "${backup_path}" || -L "${backup_path}" ]]; then
      mkdir -p "$(dirname "${dest}")"
      mv "${backup_path}" "${dest}"
      restored_count=$((restored_count + 1))
    fi
  fi

  rm -f "${MANIFEST_PATH}"
fi

cat <<EOF
pi:stow:mise:uninstall completed
  restored backups: ${restored_count}
  removed managed sandbox config: ${removed_managed_sandbox_config}
  skipped modified sandbox config: ${skipped_modified_sandbox_config}
EOF
