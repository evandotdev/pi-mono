#!/usr/bin/env bash
#MISE description="Run pi directly from local source (no Docker sandbox)"
#MISE raw=true
#MISE dir="{{cwd}}"
set -euo pipefail

args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--directory|--directory=*|-v|--volume|--volume=*)
      echo "pi:yolo: extra directory mounts are only supported by sandboxed wrappers (pi, pi:readonly, pi:shell)" >&2
      echo "pi:yolo: use mise run pi -d <path> instead" >&2
      exit 1
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

"${MISE_PROJECT_ROOT}/pi-test.sh" "${args[@]}"
