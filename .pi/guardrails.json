{
  "enabled": true,
  "features": {
    "pathProtection": true,
    "permissionGate": true
  },
  "pathProtection": {
    "zeroAccess": [
      { "pattern": ".env", "description": "environment secrets" },
      { "pattern": ".env.local", "description": "local environment secrets" },
      {
        "pattern": ".env.production",
        "description": "production environment secrets"
      },
      {
        "pattern": ".env.prod",
        "description": "production environment secrets"
      },
      { "pattern": ".dev.vars", "description": "dev environment secrets" }
    ],
    "readOnly": [],
    "noDelete": []
  },
  "permissionGate": {
    "patterns": [
      {
        "pattern": "rm -rf",
        "description": "recursive force delete",
        "tools": ["bash"],
        "targets": ["command"],
        "requireConfirmation": true
      },
      {
        "pattern": "rm -f",
        "description": "force delete",
        "tools": ["bash"],
        "targets": ["command"],
        "requireConfirmation": true
      },
      {
        "pattern": "rm -rf /",
        "description": "recursive force delete",
        "tools": ["bash"],
        "targets": ["command"],
        "requireConfirmation": true
      },
      {
        "pattern": "sudo",
        "description": "superuser command (confirmation required)",
        "tools": ["bash"],
        "targets": ["command"],
        "requireConfirmation": true
      },
      {
        "pattern": "child_process\\.(exec|execSync|spawn|spawnSync)\\s*\\(",
        "description": "node shell/process execution in generated code",
        "tools": ["write", "edit"],
        "targets": ["content"],
        "requireConfirmation": true
      },
      {
        "pattern": "\\b(subprocess\\.(run|Popen|call|check_output)|os\\.system)\\s*\\(",
        "description": "python shell/process execution in generated code",
        "tools": ["write", "edit"],
        "targets": ["content"],
        "requireConfirmation": true
      }
    ]
  }
}
