#!/usr/bin/env bash
#MISE description="Run pi directly from local source (no Docker sandbox, global wrapper)"
#MISE raw=true
#MISE dir="{{cwd}}"
set -euo pipefail

PI_MONO_ROOT="${PI_MONO_ROOT:-$HOME/pi-mono}"
PI_SCRIPT="${PI_MONO_ROOT}/.mise/tasks/pi/yolo"

if [[ ! -x "${PI_SCRIPT}" ]]; then
  echo "mise task pi:yolo: missing executable ${PI_SCRIPT}" >&2
  echo "Set PI_MONO_ROOT to your pi-mono checkout path." >&2
  exit 1
fi

MISE_PROJECT_ROOT="${PI_MONO_ROOT}" exec "${PI_SCRIPT}" "$@"
