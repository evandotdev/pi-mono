#!/usr/bin/env bash
#MISE description="Open bash shell in pi sandbox container (global wrapper)"
#MISE raw=true
#MISE dir="{{cwd}}"
set -euo pipefail

PI_MONO_ROOT="${PI_MONO_ROOT:-$HOME/pi-mono}"
PI_SCRIPT="${PI_MONO_ROOT}/.mise/tasks/pi/shell"

if [[ ! -x "${PI_SCRIPT}" ]]; then
  echo "mise task pi:shell: missing executable ${PI_SCRIPT}" >&2
  echo "Set PI_MONO_ROOT to your pi-mono checkout path." >&2
  exit 1
fi

MISE_PROJECT_ROOT="${PI_MONO_ROOT}" exec "${PI_SCRIPT}" "$@"
